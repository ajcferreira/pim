{
  "name": "pim-dam-api",
  "version": "0.1.0",
  "description": "PIM/DAM API for beverage product catalogs \u2014 dynamic attribute model on PostgreSQL",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "create-admin": "tsx scripts/create-admin.ts",
    "test": "node --import tsx --test tests/",
    "migrate": "node-pg-migrate -m migrations -d DATABASE_URL up",
    "migrate:down": "node-pg-migrate -m migrations -d DATABASE_URL down",
    "test:integration": "node --import tsx --test tests/integration/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "sharp": "^0.33.4",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "pg-boss": "^9.0.3",
    "pino": "^9.3.2",
    "node-pg-migrate": "^7.6.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2",
    "@types/cors": "^2.8.17"
  }
}